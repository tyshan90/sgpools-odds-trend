@echo off
setlocal
cd /d "%~dp0"

powershell -NoProfile -ExecutionPolicy Bypass -Command "& { $ErrorActionPreference = 'Stop'; $root = (Get-Location).Path; $runtime = Join-Path $root '.runtime'; New-Item -ItemType Directory -Force -Path $runtime | Out-Null; $python = Join-Path $root '.venv\Scripts\python.exe'; if (-not (Test-Path -LiteralPath $python)) { Write-Error 'Missing virtual environment. Run setup from README.md first.'; exit 1 }; $envArgs = @(); if ($env:SGPOOLS_ENV_FILE) { $envArgs = @('--env-file', $env:SGPOOLS_ENV_FILE) }; Write-Output 'Starting Singapore Pools odds scraper loop...'; $scraperArgs = @('-m','sgpools_trend.cli') + $envArgs + @('scrape-loop','--interval-minutes','10'); $scraper = Start-Process -FilePath $python -ArgumentList $scraperArgs -WorkingDirectory $root -RedirectStandardOutput (Join-Path $runtime 'scraper.log') -RedirectStandardError (Join-Path $runtime 'scraper.err.log') -PassThru -WindowStyle Hidden; Set-Content -Encoding ascii -LiteralPath (Join-Path $runtime 'scraper.pid') -Value $scraper.Id; if (-not $env:SGPOOLS_ENV_FILE -and -not $env:TELEGRAM_BOT_TOKEN) { Write-Output 'TELEGRAM_BOT_TOKEN or SGPOOLS_ENV_FILE is not set. Skipping Telegram bot.'; Write-Output 'Scraper started. PID file: .runtime\scraper.pid'; exit 0 }; Write-Output 'Starting Telegram bot...'; $botArgs = @('-m','sgpools_trend.bot') + $envArgs; $bot = Start-Process -FilePath $python -ArgumentList $botArgs -WorkingDirectory $root -RedirectStandardOutput (Join-Path $runtime 'bot.log') -RedirectStandardError (Join-Path $runtime 'bot.err.log') -PassThru -WindowStyle Hidden; Set-Content -Encoding ascii -LiteralPath (Join-Path $runtime 'bot.pid') -Value $bot.Id; Write-Output 'Started.'; Write-Output 'Scraper PID: .runtime\scraper.pid'; Write-Output 'Bot PID: .runtime\bot.pid' }"
